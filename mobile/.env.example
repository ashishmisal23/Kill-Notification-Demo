# ============================================
# Mobile App Environment Configuration
# ============================================

# Backend API Server
# Replace with your actual development machine's local IP address
# Run: ipconfig getifaddr en0 (macOS) or ifconfig | grep "inet " (Linux)
REACT_APP_API_BASE_URL=http://192.168.1.9:4000

# Environment
REACT_APP_ENV=development

# ============================================
# Platform-Specific Base URLs
# ============================================
# Use one of the following based on your testing platform:

# For Android emulator (default):
# REACT_APP_API_BASE_URL=http://10.0.2.2:4000

# For iOS simulator:
# REACT_APP_API_BASE_URL=http://localhost:4000

# For physical device on same WiFi network:
# REACT_APP_API_BASE_URL=http://192.168.1.9:4000

# For production backend:
# REACT_APP_API_BASE_URL=https://your-production-backend.com

# ============================================
# IMPORTANT SETUP INSTRUCTIONS
# ============================================
# 1. Copy this file: cp .env.example .env
# 2. Find your machine's local IP:
#    macOS: ipconfig getifaddr en0
#    Linux: hostname -I | awk '{print $1}'
# 3. Update REACT_APP_API_BASE_URL with your IP:4000
#    Example: http://192.168.1.9:4000
# 4. Make sure backend is running: npm start (in NotificationBackend folder)
# 5. Start the mobile app: npx react-native run-android
