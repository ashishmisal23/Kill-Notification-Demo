# ============================================
# Backend Environment Configuration
# ============================================

# Server
PORT=4000
NODE_ENV=development

# MongoDB connection (optional but recommended for production)
# For local development: mongodb://localhost:27017/notification_demo
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/notification_demo
MONGODB_URI=mongodb://localhost:27017/notification_demo

# Firebase Admin SDK Configuration
# Choose ONE of the following options:

# Option A: Path to Firebase service account JSON file (Recommended for development)
# Download from Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Option B: Full Firebase service account JSON as environment variable (For CI/CD)
# Useful for Docker/Kubernetes or GitHub Actions
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Option C: Use Google Application Credentials (For Google Cloud deployment)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Firebase Topic Settings
DEFAULT_TOPIC=notification_demo

# ============================================
# IMPORTANT SETUP INSTRUCTIONS
# ============================================
# 1. Copy this file: cp .env.example .env
# 2. Get Firebase credentials from https://console.firebase.google.com/
# 3. Download the service account key JSON
# 4. Either:
#    a) Place JSON at ./serviceAccountKey.json and set FIREBASE_SERVICE_ACCOUNT_PATH
#    b) Or copy the JSON content and set it as FIREBASE_SERVICE_ACCOUNT_JSON
# 5. For production, use environment secrets or CI/CD tools

